# --- Локальна розробка (SQLite-файл, медіа на локальному диску) ---
# DATABASE_URI=file:./kolir.db
# PAYLOAD_SECRET=згенеруйте_випадковий_рядок

# --- Продакшен / Vercel ---
# УВАГА: справжні значення вводьте у Vercel → Settings → Environment Variables,
# а не в цьому файлі (він шаблон і потрапляє в репозиторій).

# База даних: Turso (libSQL)
DATABASE_URI=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your_turso_auth_token

# Секрет Payload (обовʼязково новий для проду): openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Сховище медіа: Vercel Blob (Storage → Blob у проєкті Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
